# Full-stack containerized devnet — env template.
#
# Canonical: docs/technical/full-stack-devnet.md.
# Issue: #146.
#
# Copy to .env at the repo root (`cp .env.example .env`) and fill in your
# values. docker-compose.full-stack.yaml reads this file automatically.

# ----- Anvil fork (required) -----------------------------------------------

# Public-chain archive RPC URL used by Anvil's --fork-url. Alchemy / Infura /
# QuickNode work; the URL must support eth_getStorageAt and debug_traceCall
# at the pin block. Never commit a real key.
RMPC_FORK_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Pin block number. Refresh per docs/technical/fork-e2e-decisions.md §3.2.
# Example value (Base mainnet, valid 2026-05-07):
RMPC_FORK_BLOCK=29800000

# Chain id of the forked network. Defaults to 8453 (Base mainnet).
FORK_CHAIN_ID=8453

# Anvil mnemonic. The default below is the public Foundry test mnemonic so
# that the deployer addresses are pre-funded. Override only if you know
# what you are doing.
ANVIL_MNEMONIC=test test test test test test test test test test test junk

# ----- Gateway deploy roles (optional) -------------------------------------

# Override deploy-time role assignments. Defaults match Anvil mnemonic
# indices 0..3 and are set inline in docker-compose.full-stack.yaml.
# ADMIN_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
# PAUSER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
# AGENT_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
# SHARE_RECEIVER_ADDRESS=0x90F79bf6EB2c4f870365E785982E1f101E93b906

# ----- Postgres (required for explorer) -----------------------------------

POSTGRES_USER=rmoney
POSTGRES_PASSWORD=rmoney_dev
POSTGRES_DB=rmoney_explorer

# ----- Explorer indexer (Phase 5) -----------------------------------------

# Stored on the chains row for the indexed chain. Cosmetic.
INDEXER_CHAIN_NAME=base-fork

# Tick interval in seconds. Default 12 (one Base block-time).
INDEXER_TICK_SECONDS=12

# Per-tick block range cap.
INDEXER_MAX_BLOCKS_PER_TICK=1000

# ----- Explorer API (Phase 5) ---------------------------------------------

# Host port; container listens on :8080 internally.
EXPLORER_API_PORT=8080

# ----- Dapp (Phase 6) -----------------------------------------------------

# Browser-routable URLs (Vite inlines these into the bundle at build time).
# Defaults assume localhost; override for hosted deployments.
VITE_FORK_RPC_URL=http://localhost:8545
VITE_EXPLORER_API_URL=http://localhost:8080

# Environment class. MUST be `fork` or `devnet` outside production.
VITE_ENV_CLASS=fork

# Wallet flags. Mock wallet is enabled by default for the devnet build so
# the dapp boots without a browser-extension wallet.
VITE_USE_MOCK_WALLET=true
VITE_BROWSER_KEYGEN=false
VITE_HISTORY_PANE=true
