// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TxPreview snapshots — role grant/revoke (issue #83) > renders structured preview for grant ADMIN_ROLE 1`] = `"<section data-testid="tx-preview" data-ok="true" class="tx-preview"><header><h3 data-testid="tx-preview-fn">grantRole</h3><span data-testid="tx-preview-risk" style="background: rgb(211, 47, 47); color: white; padding: 2px 8px;">HIGH</span></header><dl><dt>Target</dt><dd data-testid="tx-preview-target">0x1111111111111111111111111111111111111111 <span data-testid="tx-preview-codehash">[bytecode verified]</span></dd><dt>Selector</dt><dd data-testid="tx-preview-selector">0x2f2ff15d</dd><dt>Decoded args</dt><dd><ul data-testid="tx-preview-args"><li><code>role</code> = <code>0xa49807205ce4d355092ef5a8a18f56e8913cf4a201fbe287825b095693c21775</code> — <em>ADMIN_ROLE (keccak256 of role string)</em></li><li><code>account</code> = <code>0x70997970C51812dc3A010C7d01b50e0d17dc79C8</code> — <em>ADMIN_ROLE holder 0x7099...79C8</em></li></ul></dd><dt>Effect</dt><dd data-testid="tx-preview-effect">Address 0x7099...79C8 will hold ADMIN_ROLE; this lets it authorize/revoke agents, edit policy, and call unpause(). Mutually exclusive with AGENT_ROLE and PAUSER_ROLE on the same account (enforced by AccessRoles._grantRole).</dd></dl><details data-testid="tx-preview-calldata-details"><summary>Raw calldata (paranoid-operator copy buffer)</summary><code data-testid="tx-preview-calldata">0x2f2ff15da49807205ce4d355092ef5a8a18f56e8913cf4a201fbe287825b095693c2177500000000000000000000000070997970c51812dc3a010c7d01b50e0d17dc79c8</code></details></section>"`;

exports[`TxPreview snapshots — role grant/revoke (issue #83) > renders structured preview for grant PAUSER_ROLE 1`] = `"<section data-testid="tx-preview" data-ok="true" class="tx-preview"><header><h3 data-testid="tx-preview-fn">grantRole</h3><span data-testid="tx-preview-risk" style="background: rgb(211, 47, 47); color: white; padding: 2px 8px;">HIGH</span></header><dl><dt>Target</dt><dd data-testid="tx-preview-target">0x1111111111111111111111111111111111111111 <span data-testid="tx-preview-codehash">[bytecode verified]</span></dd><dt>Selector</dt><dd data-testid="tx-preview-selector">0x2f2ff15d</dd><dt>Decoded args</dt><dd><ul data-testid="tx-preview-args"><li><code>role</code> = <code>0x65d7a28e3265b37a6474929f336521b332c1681b933f6cb9f3376673440d862a</code> — <em>PAUSER_ROLE (keccak256 of role string)</em></li><li><code>account</code> = <code>0x70997970C51812dc3A010C7d01b50e0d17dc79C8</code> — <em>PAUSER_ROLE holder 0x7099...79C8</em></li></ul></dd><dt>Effect</dt><dd data-testid="tx-preview-effect">Address 0x7099...79C8 will hold PAUSER_ROLE; this lets it call pause() (asymmetric — unpause requires ADMIN_ROLE). Mutually exclusive with AGENT_ROLE and ADMIN_ROLE on the same account.</dd></dl><details data-testid="tx-preview-calldata-details"><summary>Raw calldata (paranoid-operator copy buffer)</summary><code data-testid="tx-preview-calldata">0x2f2ff15d65d7a28e3265b37a6474929f336521b332c1681b933f6cb9f3376673440d862a00000000000000000000000070997970c51812dc3a010c7d01b50e0d17dc79c8</code></details></section>"`;

exports[`TxPreview snapshots — role grant/revoke (issue #83) > renders structured preview for revoke ADMIN_ROLE 1`] = `"<section data-testid="tx-preview" data-ok="true" class="tx-preview"><header><h3 data-testid="tx-preview-fn">revokeRole</h3><span data-testid="tx-preview-risk" style="background: rgb(46, 125, 50); color: white; padding: 2px 8px;">LOW</span></header><dl><dt>Target</dt><dd data-testid="tx-preview-target">0x1111111111111111111111111111111111111111 <span data-testid="tx-preview-codehash">[bytecode verified]</span></dd><dt>Selector</dt><dd data-testid="tx-preview-selector">0xd547741f</dd><dt>Decoded args</dt><dd><ul data-testid="tx-preview-args"><li><code>role</code> = <code>0xa49807205ce4d355092ef5a8a18f56e8913cf4a201fbe287825b095693c21775</code> — <em>ADMIN_ROLE (keccak256 of role string)</em></li><li><code>account</code> = <code>0x70997970C51812dc3A010C7d01b50e0d17dc79C8</code> — <em>ADMIN_ROLE holder 0x7099...79C8</em></li></ul></dd><dt>Effect</dt><dd data-testid="tx-preview-effect">Address 0x7099...79C8 loses ADMIN_ROLE; subsequent authorizeAgent/revokeAgent/unpause calls from this account revert. The contract still requires at least one DEFAULT_ADMIN_ROLE holder for recovery.</dd></dl><details data-testid="tx-preview-calldata-details"><summary>Raw calldata (paranoid-operator copy buffer)</summary><code data-testid="tx-preview-calldata">0xd547741fa49807205ce4d355092ef5a8a18f56e8913cf4a201fbe287825b095693c2177500000000000000000000000070997970c51812dc3a010c7d01b50e0d17dc79c8</code></details></section>"`;

exports[`TxPreview snapshots — role grant/revoke (issue #83) > renders structured preview for revoke PAUSER_ROLE 1`] = `"<section data-testid="tx-preview" data-ok="true" class="tx-preview"><header><h3 data-testid="tx-preview-fn">revokeRole</h3><span data-testid="tx-preview-risk" style="background: rgb(46, 125, 50); color: white; padding: 2px 8px;">LOW</span></header><dl><dt>Target</dt><dd data-testid="tx-preview-target">0x1111111111111111111111111111111111111111 <span data-testid="tx-preview-codehash">[bytecode verified]</span></dd><dt>Selector</dt><dd data-testid="tx-preview-selector">0xd547741f</dd><dt>Decoded args</dt><dd><ul data-testid="tx-preview-args"><li><code>role</code> = <code>0x65d7a28e3265b37a6474929f336521b332c1681b933f6cb9f3376673440d862a</code> — <em>PAUSER_ROLE (keccak256 of role string)</em></li><li><code>account</code> = <code>0x70997970C51812dc3A010C7d01b50e0d17dc79C8</code> — <em>PAUSER_ROLE holder 0x7099...79C8</em></li></ul></dd><dt>Effect</dt><dd data-testid="tx-preview-effect">Address 0x7099...79C8 loses PAUSER_ROLE; subsequent pause() calls from this account revert. Other PAUSER_ROLE holders (if any) are unaffected.</dd></dl><details data-testid="tx-preview-calldata-details"><summary>Raw calldata (paranoid-operator copy buffer)</summary><code data-testid="tx-preview-calldata">0xd547741f65d7a28e3265b37a6474929f336521b332c1681b933f6cb9f3376673440d862a00000000000000000000000070997970c51812dc3a010c7d01b50e0d17dc79c8</code></details></section>"`;
