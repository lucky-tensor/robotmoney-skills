# Dapp build-time environment variables.
#
# Copy this file to .env and fill in the values for your deployment.
# All variables are passed as Docker build args — Vite inlines them into
# the static bundle at build time. A rebuild is required after any change.
#
# Usage with docker-compose:
#   cp .env.example .env
#   docker compose --env-file .env up --build

# RPC endpoint for the target network (fork, devnet, testnet, or mainnet)
VITE_FORK_RPC_URL=http://localhost:8545

# Explorer/indexer API for transaction history
VITE_EXPLORER_API_URL=http://localhost:8080

# Deployed Gateway contract address
VITE_GATEWAY_ADDRESS=0x0000000000000000000000000000000000000000

# Deployed Vault contract address
VITE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Keccak-256 of the gateway runtime bytecode. The dapp refuses admin
# writes until this matches what the chain reports. Operators must
# pin this value per deployment.
VITE_GATEWAY_EXPECTED_CODE_HASH=

# Set to true once the gateway bytecode hash has been verified against the
# expected value — the dapp will refuse admin ops if this is false
VITE_GATEWAY_CODE_HASH_VERIFIED=false

# One of: fork | devnet | testnet | mainnet
VITE_ENV_CLASS=fork

# Browser-keygen is gated behind a security review (ADR §3.1) — leave false
VITE_BROWSER_KEYGEN=false

# Enable transaction history pane
VITE_HISTORY_PANE=false

# Issue #261 — 32-byte hex private key of the smoke-test USDC holder EOA.
# Inlined into the dapp bundle ONLY for testnet/devnet builds; mainnet
# operator builds must leave this empty. When unset, the FaucetTab and
# onboarding USDC seed step fail closed. Source: testing/smoke-test/src/lib.rs
# `HARNESS_USDC_HOLDER_PRIVATE_KEY_HEX`.
VITE_FAUCET_HARNESS_PRIVATE_KEY=
